import React from 'react'
import products from './Mini_Project/Products'
import Template from './Mini_Project/Template'
import './Mini_Project/Mini_Project.css';
import { FaShoppingCart } from "react-icons/fa";

const App = () => {
  return (
    <div className="container">
      {products.map((product) => (
        <Template
          key={product.id}
          name={product.name}
          image={product.image}
          size={product.size}
          color={product.color}
          description={product.description}
          price={product.price}
        />
      ))}
    </div>
  )
}

export default App